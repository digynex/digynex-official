    {
      "parameters": {
        "jsCode": "const inputCountry = ($node[\"Webhook: Job Request\"].json.query.country || 'sweden').toLowerCase();\nconst inputCity = ($node[\"Webhook: Job Request\"].json.query.city || '').toLowerCase();\nconst inputKeyword = ($node[\"Webhook: Job Request\"].json.query.q || '').toLowerCase(); // 🎯 KEYWORD RECOVERED (CRITICAL FIX)\n\n// 🌍 GLOBAL STRATEGIC MAPPING (V16.9.5)\nconst countryMap = {\n  'sweden': 'se',\n  'germany': 'de',\n  'united kingdom': 'gb',\n  'norway': 'no',\n  'finland': 'fi',\n  'denmark': 'dk',\n  'sri lanka': 'lk',\n  'united states': 'us',\n  'canada': 'ca',\n  'australia': 'au',\n  'france': 'fr',\n  'netherlands': 'nl'\n};\n\nconst finalCountryCode = countryMap[inputCountry] || inputCountry;\n\n// 🛰️ DYNAMIC PROVIDER STRATEGY\n// Adzuna supports specific countries. Fallback to Careerjet for others.\nconst adzunaSupported = ['at','au','be','br','ca','ch','de','es','fr','gb','in','it','mx','nl','nz','pl','ru','us','za', 'se'];\nconst provider = adzunaSupported.includes(finalCountryCode) ? 'adzuna' : 'careerjet';\n\nconst localeMap = {\n  'se': 'sv_SE',\n  'de': 'de_DE',\n  'gb': 'en_GB',\n  'no': 'no_NO',\n  'lk': 'en_LK',\n  'fi': 'fi_FI',\n  'dk': 'da_DK'\n};\n\nconst localeCode = localeMap[finalCountryCode] || 'en_GB';\n\n// 🛡️ SURGICAL SEARCH KEY (V16.9.5)\n// Ensures the cache lookup is 100% accurate based on keyword + country + city\nconst uniqueSearchKey = `${inputKeyword}_${finalCountryCode}_${inputCity}`.replace(/__+/g, '_').trim();\n\n// 🚀 NEURAL RETURN PAYLOAD\nreturn {\n  keyword: inputKeyword,\n  search_key: uniqueSearchKey, // ✅ Use this in Supabase nodes!\n  country: finalCountryCode,\n  countryCode: finalCountryCode, \n  locale: localeCode,\n  provider: provider,\n  city: inputCity,\n  original_input: inputCountry\n};\n"
      },
