    {
      "parameters": {
        "jsCode": "let rawData = $input.item.json;\n\n// Handle error output from Adzuna if it somehow reaches here\nif (rawData.error) return { jobs: [] };\n\n// Handle stringified JSON from Careerjet\nif (typeof rawData.data === 'string') {\n  try { rawData = JSON.parse(rawData.data); } catch (e) {}\n} else if (rawData.data && typeof rawData.data === 'object') {\n  rawData = rawData.data;\n}\n\nconst results = rawData.results || rawData.jobs || [];\nconst keyword = $node['Code: Map Country'].json.keyword.toLowerCase();\nconst country = $node['Code: Map Country'].json.countryCode;\n\nconst formattedJobs = results.map((job, index) => ({\n  id: job.id || String(index),\n  company: job.company?.display_name || job.company || 'Unknown Company',\n  title: job.title,\n  location: job.location?.display_name || job.location || 'Remote',\n  match_score: Math.floor(Math.random() * 20) + 80,\n  url: job.redirect_url || job.url,\n  description: job.description\n}));\n\nreturn {\n  search_key: `${keyword}_${country}`,\n  jobs: formattedJobs\n};"
      },
